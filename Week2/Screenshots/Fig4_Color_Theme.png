<line x1="20" y1="38" x2="660" y2="40" stroke="#c8b89a" stroke-width="1" stroke-dasharray="4,2" style="fill:rgb(0, 0, 0);stroke:rgb(200, 184, 154);color:rgb(255, 255, 255);stroke-width:1px;stroke-dasharray:4px, 2px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

